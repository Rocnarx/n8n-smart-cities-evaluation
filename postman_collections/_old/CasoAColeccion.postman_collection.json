{
  "info": {
    "name": "n8n E2E - Recarga Tullave",
    "_postman_id": "bf49a4d8-2ff2-4419-8c60-7e093b06a538",
    "description": "Colección Postman para probar el flujo end-to-end de n8n con mocks FastAPI.\n\nImporta también el environment adjunto.\nPor defecto n8n_webhook_url apunta a /webhook-test y mock_base_url a http://host.docker.internal:8000.\nSi activas/publicas el workflow, cambia n8n_webhook_url por n8n_webhook_url_prod.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "n8n_webhook_url",
      "value": "http://localhost:5678/webhook-test/casoA-recarga-tullave-v2",
      "type": "string"
    },
    {
      "key": "n8n_webhook_url_prod",
      "value": "http://localhost:5678/webhook/casoA-recarga-tullave-v2",
      "type": "string"
    },
    {
      "key": "mock_base_url",
      "value": "http://host.docker.internal:8000",
      "type": "string"
    },
    {
      "key": "cid",
      "value": "test-correlation-001",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "E2E - n8n Webhook",
      "description": "Requests end-to-end contra el webhook de n8n. Por defecto usan la URL de prueba.",
      "item": [
        {
          "name": "E2E 01 - Éxito completo",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "X-Correlation-ID",
                "value": "{{cid}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mock_base_url\": \"{{mock_base_url}}\",\n  \"transaction_id\": \"tx-e2e-ok-001\",\n  \"payment_status\": \"APPROVED\",\n  \"amount\": 12000,\n  \"account_balance\": 50000\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{n8n_webhook_url}}",
            "description": "Camino feliz completo."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code es 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Respuesta JSON', function () {",
                  "    pm.response.to.be.json;",
                  "});"
                ]
              }
            }
          ]
        },
